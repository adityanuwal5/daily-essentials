# Copy to `.env` and adjust for your environment. Never commit the real .env.
# These are read by core/settings.py at startup.

# Cryptographic signing key. Generate a fresh one for any real deployment:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-value

# Debug toggle. MUST be false in production.
DJANGO_DEBUG=true

# Comma-separated hosts allowed to serve this app.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated browser origins permitted by CORS (the React dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
