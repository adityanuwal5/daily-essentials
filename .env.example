# DailyEssentials backend — environment variables.
# Copy to `.env` for local use (`.env` is gitignored). In production (Vercel),
# set these in Dashboard > Settings > Environment Variables instead.

# --- Security ---
# Generate a fresh one for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-in-production

# MUST be False in production. Leave unset locally to keep the dev default (True).
DJANGO_DEBUG=False

# Comma-separated hosts. Add your Vercel domain in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-app.vercel.app

# --- Database ---
# LEAVE THIS UNSET LOCALLY — the app falls back to SQLite automatically.
# In production, paste the cloud PostgreSQL connection string from Neon/Supabase:
#   postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# --- CORS (browser origins allowed to call the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
