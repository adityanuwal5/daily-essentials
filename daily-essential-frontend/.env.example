# Base URL of the Django REST API.
# Points directly at the local Django dev server. The Axios client
# (src/api/axios.js) falls back to this same default if unset.
VITE_API_BASE_URL=http://localhost:8000/api/

# Set to "true" to use the bundled mock data instead of hitting the API.
# Defaults to live ("false"); flip to "true" for offline UI development.
VITE_USE_MOCK=false
